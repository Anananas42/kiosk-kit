#!/usr/bin/env bash
# Wrapper around gh CLI to enforce PR and branch naming conventions.
# Placed on PATH before the real gh binary inside the agent container.

set -euo pipefail

REAL_GH=$(which -a gh | grep -v "$(dirname "$0")" | head -1)

# --- Enforce PR title convention ---
# Must match: type(KIO-N): description
# Types: feat, fix, refactor, docs, test, chore, ci
if [ "${1:-}" = "pr" ] && [ "${2:-}" = "create" ]; then
  TITLE=""
  for i in $(seq 1 $#); do
    arg="${!i}"
    if [ "$arg" = "--title" ]; then
      next=$((i + 1))
      TITLE="${!next}"
      break
    fi
  done

  if [ -n "$TITLE" ]; then
    if ! echo "$TITLE" | grep -qE '^(feat|fix|refactor|docs|test|chore|ci)\(KIO-[0-9]+\): .+'; then
      echo "ERROR: PR title must match convention: type(KIO-N): description" >&2
      echo "  Types: feat, fix, refactor, docs, test, chore, ci" >&2
      echo "  Example: feat(KIO-15): add user authentication" >&2
      echo "  Got: $TITLE" >&2
      exit 1
    fi
  fi
fi

exec "$REAL_GH" "$@"
