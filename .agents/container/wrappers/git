#!/usr/bin/env bash
# Wrapper around git to enforce branch naming conventions.
# Placed on PATH before the real git binary inside the agent container.

set -euo pipefail

REAL_GIT=/usr/bin/git

# --- Enforce branch naming on checkout -b / switch -c ---
NEW_BRANCH=""
if [ "${1:-}" = "checkout" ] && [ "${2:-}" = "-b" ]; then
  NEW_BRANCH="${3:-}"
elif [ "${1:-}" = "switch" ] && [ "${2:-}" = "-c" ]; then
  NEW_BRANCH="${3:-}"
fi

if [ -n "$NEW_BRANCH" ] && [ "$NEW_BRANCH" != "main" ]; then
  # Must match: kio-N/description
  if ! echo "$NEW_BRANCH" | grep -qE '^kio-[0-9]+/[a-z0-9-]+$'; then
    echo "ERROR: Branch name must match: kio-<number>/<description>" >&2
    echo "  Example: kio-15/add-user-auth" >&2
    echo "  Got: $NEW_BRANCH" >&2
    exit 1
  fi
fi

# --- Block commit and push on main ---
CURRENT_BRANCH=$("$REAL_GIT" branch --show-current 2>/dev/null || true)
if [ "$CURRENT_BRANCH" = "main" ]; then
  if [ "${1:-}" = "commit" ]; then
    echo "ERROR: Cannot commit directly on main." >&2
    echo "  You must create a feature branch first." >&2
    echo "  Re-read the cicd-workflow skill in CLAUDE.md and follow the full workflow:" >&2
    echo "    1. git checkout -b kio-<id>/<description>" >&2
    echo "    2. Make changes and commit on the feature branch" >&2
    echo "    3. Push and open a PR" >&2
    exit 1
  fi
  if [ "${1:-}" = "push" ]; then
    echo "ERROR: Cannot push directly to main." >&2
    echo "  You must create a feature branch and open a PR." >&2
    echo "  Re-read the cicd-workflow skill in CLAUDE.md and follow the full workflow:" >&2
    echo "    1. git checkout -b kio-<id>/<description>" >&2
    echo "    2. Make changes and commit on the feature branch" >&2
    echo "    3. Push and open a PR" >&2
    exit 1
  fi
fi

exec "$REAL_GIT" "$@"
