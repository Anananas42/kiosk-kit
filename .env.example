# Server port
PORT=3001

# Database — ALWAYS use local Docker Postgres for development.
# Production Neon URL lives ONLY in GitHub secrets. Never set it here.
DATABASE_URL=postgresql://kioskkit:kioskkit@localhost:5433/kioskkit

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3002/api/auth/google/callback

# MCP server API keys (used by Claude Code and agent containers)
LINEAR_API_KEY=
NEON_API_KEY=
STITCH_API_KEY=
