# ── Web Server ───────────────────────────────────────────
NODE_ENV=development
DATABASE_URL=postgresql://kioskkit:kioskkit@localhost:5433/kioskkit

# Cross-subdomain cookie domain (e.g. ".kioskk.net"). Omit for local dev.
COOKIE_DOMAIN=

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3002/api/auth/google/callback

# ── MCP Tools (Claude Code / agent containers) ──────────
LINEAR_API_KEY=
NEON_API_KEY=
STITCH_API_KEY=
