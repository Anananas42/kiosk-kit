# ── Web Server ───────────────────────────────────────────
NODE_ENV=development
DATABASE_URL=postgresql://kioskkit:kioskkit@localhost:5433/kioskkit

# Cross-subdomain cookie domain (e.g. ".kioskk.net"). Omit for local dev.
COOKIE_DOMAIN=

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3002/api/auth/google/callback

# Tailscale OAuth (create at https://login.tailscale.com/admin/settings/oauth)
# Scopes: devices:core (tags: tag:kioskkit, tag:server) + auth_keys
TAILSCALE_OAUTH_CLIENT_ID=
TAILSCALE_OAUTH_CLIENT_SECRET=
TAILSCALE_TAILNET=

# S3-compatible object storage (used for device backups)
S3_ENDPOINT=
S3_BUCKET=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_REGION=us-east-1

# ── MCP Tools (Claude Code / agent containers) ──────────
LINEAR_API_KEY=
NEON_API_KEY=
STITCH_API_KEY=
