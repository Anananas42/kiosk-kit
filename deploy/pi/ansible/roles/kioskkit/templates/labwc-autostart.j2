#!/bin/sh
# Managed by Ansible — do not edit manually.
# labwc autostart — launched by labwc after the compositor is ready.
# App-level timing constants live in packages/shared/src/config.ts.

chromium \
    --kiosk \
    --noerrdialogs \
    --disable-renderer-backgrounding \
    --disable-background-timer-throttling \
    --disable-infobars \
    --disable-translate \
    --no-first-run \
    --disable-features=TranslateUI \
    --disable-session-crashed-bubble \
    --disable-component-update \
    --autoplay-policy=no-user-gesture-required \
    --password-store=basic \
    --ozone-platform=wayland \
    --force-device-scale-factor={{ kioskkit_display_scale_factor }} \
    http://localhost:{{ kioskkit_app_port }} &
