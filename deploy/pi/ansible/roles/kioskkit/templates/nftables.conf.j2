#!/usr/sbin/nft -f
# Managed by Ansible — do not edit manually.
# Pi-passive model: no outbound except Tailscale + DHCP + wlan0 DNS/DHCP.

flush ruleset

table inet filter {
    chain input {
        type filter hook input priority 0; policy drop;

        # Loopback
        iif lo accept

        # Established/related connections
        ct state established,related accept

        # SSH from any IP (Tailscale or local provisioning)
        tcp dport 22 accept

        # Tailscale tunnel interface — all traffic trusted
        iifname "tailscale0" accept
    }

    chain forward {
        type filter hook forward priority 0; policy drop;
    }

    chain output {
        type filter hook output priority 0; policy drop;

        # Loopback
        oif lo accept

        # Established/related
        ct state established,related accept

        # DNS + DHCP (needed on any interface for initial network + Tailscale auth)
        udp dport 53 accept
        udp dport { 67, 68 } accept

        # Tailscale control plane (HTTPS for auth, WireGuard UDP for tunnel)
        tcp dport 443 accept
        udp dport 41641 accept
    }
}
