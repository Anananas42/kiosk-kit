#!/bin/bash
# fake-systemctl — Wrapper for use inside chroot during image builds.
#
# Intercepts systemctl commands that would fail without a running systemd
# (enable, disable, daemon-reload, start, stop, restart, is-enabled, cat).
# Passes everything else through to the real systemctl.
#
# This is a well-established pattern used by pi-gen (official Pi image builder)
# and other chroot-based image build tools.
#
# WARNING: This file must be REMOVED from the image after Ansible finishes.
# It lives at /usr/local/bin/systemctl which takes PATH precedence over
# /usr/bin/systemctl.

set -euo pipefail

REAL_SYSTEMCTL="/usr/bin/systemctl"

resolve_unit_file() {
  local unit="$1"
  for dir in /etc/systemd/system /lib/systemd/system /usr/lib/systemd/system; do
    if [[ -f "$dir/$unit" ]]; then
      echo "$dir/$unit"
      return 0
    fi
  done
  return 1
}

get_wanted_by() {
  local unit_file="$1"
  local wanted_by
  wanted_by=$(sed -n '/^\[Install\]/,/^\[/{ s/^WantedBy=//p }' "$unit_file" 2>/dev/null | tr ' ' '\n' | head -1)
  echo "${wanted_by:-multi-user.target}"
}

cmd="${1:-}"
shift || true

case "$cmd" in
  enable)
    for unit in "$@"; do
      # Strip --now or other flags
      [[ "$unit" == --* ]] && continue
      unit_file=$(resolve_unit_file "$unit") || continue
      target=$(get_wanted_by "$unit_file")
      mkdir -p "/etc/systemd/system/${target}.wants"
      ln -sf "$unit_file" "/etc/systemd/system/${target}.wants/$unit"
    done
    ;;

  disable)
    for unit in "$@"; do
      [[ "$unit" == --* ]] && continue
      # Remove from all target wants directories
      find /etc/systemd/system -name "$unit" -path "*.wants/*" -delete 2>/dev/null || true
    done
    ;;

  daemon-reload|start|stop|restart|reload|try-restart|reload-or-restart)
    # Silently succeed — no running systemd to talk to
    exit 0
    ;;

  is-enabled)
    unit="${1:-}"
    if find /etc/systemd/system -name "$unit" -path "*.wants/*" -print -quit 2>/dev/null | grep -q .; then
      echo "enabled"
      exit 0
    else
      echo "disabled"
      exit 1
    fi
    ;;

  cat)
    unit="${1:-}"
    unit_file=$(resolve_unit_file "$unit") || { echo "Unit $unit not found." >&2; exit 1; }
    cat "$unit_file"
    ;;

  is-active)
    # Nothing is active in a chroot
    echo "inactive"
    exit 3
    ;;

  set-default)
    # Create the default.target symlink
    target="${1:-}"
    ln -sf "/lib/systemd/system/$target" /etc/systemd/system/default.target
    ;;

  *)
    # Pass through to real systemctl
    if [[ -x "$REAL_SYSTEMCTL" ]]; then
      exec "$REAL_SYSTEMCTL" "$cmd" "$@"
    else
      echo "fake-systemctl: unknown command '$cmd' and real systemctl not found" >&2
      exit 1
    fi
    ;;
esac
