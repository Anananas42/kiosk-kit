# Sway compositor config for kiosk mode.
# App-level timing constants live in packages/shared/src/config.ts.
# Display-off timeout (2700s/45min) and wake grab hold (4s) are system-level
# and kept here / in display-sleep.py respectively.

seat * hide_cursor 1
default_border none
default_floating_border none

exec swayidle -w timeout 2700 '/opt/kioskkit/system/config/display-sleep.py'

exec chromium \
    --kiosk \
    --noerrdialogs \
    --disable-renderer-backgrounding \
    --disable-background-timer-throttling \
    --disable-infobars \
    --disable-translate \
    --no-first-run \
    --disable-features=TranslateUI \
    --disable-session-crashed-bubble \
    --disable-component-update \
    --autoplay-policy=no-user-gesture-required \
    --password-store=basic \
    --ozone-platform=wayland \
    --force-device-scale-factor=1.6 \
    http://localhost:3001
