{
  "name": "kioskkit",
  "private": true,
  "packageManager": "pnpm@10.33.0+sha512.10568bb4a6afb58c9eb3630da90cc9516417abebd3fabbe6739f0ae795728da1491e9db5a544c76ad8eb7570f5c4bb3d6c637b2cb41bfdcdb47fa823c8649319",
  "scripts": {
    "dev": "./scripts/dev.sh",
    "dev:web": "./scripts/dev.sh web",
    "dev:kiosk": "./scripts/dev.sh kiosk",
    "dev:kiosk-emu": "./scripts/dev.sh kiosk-emu",
    "dev:landing": "./scripts/dev.sh landing",
    "build": "turbo build",
    "typecheck": "turbo typecheck",
    "lint": "biome check .",
    "lint:fix": "biome check --fix .",
    "lint:shell": "find . -name '*.sh' -not -path './node_modules/*' -not -path './ansible/.venv/*' -not -path './.husky/*' -print0 | xargs -0 shellcheck --severity=warning",
    "test": "vitest run",
    "start:kiosk": "node packages/kiosk-server/dist/index.js",
    "test:pi-emulator": "dev/pi-emulator/test.sh",
    "storybook": "pnpm --filter @kioskkit/ui storybook",
    "build-storybook": "pnpm --filter @kioskkit/ui build-storybook",
    "screenshot": "node dev/agents/scripts/screenshot.mjs",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,tsx,js,json}": [
      "biome check --fix --no-errors-on-unmatched"
    ],
    "*.sh": [
      "shellcheck --severity=warning"
    ]
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "esbuild",
      "sharp"
    ]
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.8",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "playwright": "^1.58.2",
    "turbo": "^2.8.20",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0"
  }
}
