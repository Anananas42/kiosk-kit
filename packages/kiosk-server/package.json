{
  "name": "@kioskkit/kiosk-server",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "exports": {
    "./trpc": {
      "types": "./src/trpc/router.ts"
    }
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "seed": "tsx src/seed.ts",
    "db:generate": "drizzle-kit generate",
    "db:push": "drizzle-kit push",
    "db:migrate": "drizzle-kit migrate",
    "db:reseed": "rm -rf data/sqlite.db && tsx src/seed.ts"
  },
  "dependencies": {
    "@hono/node-server": "^1.13.8",
    "@hono/standard-validator": "^0.2.2",
    "@hono/trpc-server": "^0.4.2",
    "@kioskkit/shared": "workspace:*",
    "@scalar/hono-api-reference": "^0.10.4",
    "@trpc/server": "^11.15.0",
    "better-sqlite3": "^11.8.1",
    "dotenv": "^16.4.7",
    "drizzle-orm": "^0.45.1",
    "hono": "^4.7.4",
    "hono-openapi": "^1.3.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.13.4",
    "drizzle-kit": "^0.31.10",
    "tsup": "^8.3.6",
    "tsx": "^4.19.2",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0"
  }
}
